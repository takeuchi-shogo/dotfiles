sample-dotfiles

/.git

.DS_Store
*.log

/.config/sketchybar/noice.log

settings.local.json
CLAUDE.local.md

# Claude Code local runtime state
.claude/agent-memory/
.claude/channels/
.claude/scheduled_tasks.lock

# Machine-local zsh config
.config/zsh/local.zsh

# Claude reviewer persona (contains personal data)
.config/claude/agents/reviewer-*.md
.config/claude/data/*
# 例外: 公開 OK な設定データ
!.config/claude/data/trusted-domains.json
__pycache__/
.worktrees/

# Raycast secrets
.config/raycast/**/secrets*
.config/raycast/**/*token*
.config/raycast/**/*api_key*

# Design/plan docs (session artifacts, not version-controlled)
docs/plans/

# Session artifacts (audit reports, running briefs)
# RUNNING_BRIEF.md/HANDOFF.md are updated by /checkpoint skill, QUESTIONS-*.md by /audit skill.
# Both are personal session state, not version-controlled artifacts.
RUNNING_BRIEF.md
HANDOFF.md
QUESTIONS-*.md

# npx skills artifacts
.agent/
.kiro/
skills-lock.json
skills-lock.json.bak-*
skills-lock-history/
.skill-eval/

# Benchmark/research artifacts (skill-audit等で生成される一時ファイル)
.claude/react/
.claude/research/

# Research working directory (中間ファイル。最終レポートは docs/research/ に保存)
.research/

# Reviewer eval results (実行ごとに生成されるローカルデータ)
.config/claude/scripts/eval/results/

# Scratch copies. Canonical Claude runtime scripts live under .config/claude/scripts/runtime/
scripts/runtime/auto-morning-briefing.sh
scripts/runtime/sync-memory-to-vault.sh
scripts/runtime/save-briefing-to-vault.sh

# Context knowledge base (personal learning notes)
.context/

# prompt-review reports (personal analysis data)
reports/

# Rust build artifacts
tools/claude-hooks/target/

.env

# Sample codex cc repos
everything-cc
sample-cc-best-practice
codex-best-practice

# Temporary files
tmp/
.dmux/

# Playwright MCP runtime artifacts (console logs, page snapshots)
.playwright-mcp/

# Zed editor prompts library (LMDB DB, app-local, may contain personal prompt history)
.config/zed/prompts/
