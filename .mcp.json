{
	"mcpServers": {
		"context7": {
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp@2.1.4"]
		},
"alphaxiv": {
			"type": "sse",
			"url": "https://api.alphaxiv.org/mcp/v1"
		},
		"code-review-graph": {
			"command": "uvx",
			"args": ["code-review-graph", "serve"]
		},
		"scite": {
			"type": "http",
			"url": "https://api.scite.ai/mcp"
		}
	}
}
