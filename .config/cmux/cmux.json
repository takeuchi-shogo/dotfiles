  // ===== Custom actions / commands =====
  // Worktree Agents: 新 workspace 作成時に git worktree を切り、Codex + Claude を並走起動
  // Refs: GitHub Issue #49
  // 修正点 (Codex Review Gate より):
  //   - slug に PID 付加で同一秒衝突回避
  //   - Codex/Claude pane に 60s timeout (worktree setup 失敗時の無限ループ防止)

  "actions": {
    "worktree-agents": {
      "type": "workspaceCommand",
      "title": "Worktree Agents",
      "commandName": "Worktree Agents",
      "icon": { "type": "symbol", "name": "folder.badge.plus" }
    },
    "pr-review-agent": {
      "type": "workspaceCommand",
      "title": "PR Review Agent",
      "commandName": "PR Review Agent",
      "icon": { "type": "symbol", "name": "eye.fill" }
    }
  },

  "ui": {
    "newWorkspace": {
      "action": "worktree-agents",
      "contextMenu": [
        { "action": "worktree-agents", "title": "Worktree Agents" },
        { "action": "pr-review-agent", "title": "PR Review Agent" },
        { "type": "separator" },
        { "action": "cmux.newTerminal", "title": "New Terminal" },
        { "action": "cmux.newBrowser", "title": "New Browser" }
      ]
    }
  },

  "commands": [
    {
      "name": "Worktree Agents",
      "description": "Create a fresh git worktree at .claude/worktrees/, start Codex and Claude inside it",
      "workspace": {
        "name": "Worktree Agents",
        "cwd": ".",
        "layout": {
          "direction": "horizontal",
          "split": 0.38,
          "children": [
            {
              "pane": {
                "surfaces": [
                  {
                    "type": "terminal",
                    "name": "Worktree",
                    "command": "set -euo pipefail; state=\"${TMPDIR:-/tmp}/cmux-worktree-${CMUX_WORKSPACE_ID:-manual}.dir\"; rm -f \"$state\"; repo=$(git rev-parse --show-toplevel); mkdir -p \"$repo/.claude/worktrees\"; slug=agents-$(date +%Y%m%d-%H%M%S)-$$; dir=\"$repo/.claude/worktrees/$slug\"; git -C \"$repo\" worktree add -b \"worktree-$slug\" \"$dir\"; printf \"%s\\n\" \"$dir\" > \"$state\"; cd \"$dir\"; exec \"${SHELL:-/bin/zsh}\" -l",
                    "focus": true
                  }
                ]
              }
            },
            {
              "direction": "vertical",
              "split": 0.5,
              "children": [
                {
                  "pane": {
                    "surfaces": [
                      {
                        "type": "terminal",
                        "name": "Codex",
                        "command": "state=\"${TMPDIR:-/tmp}/cmux-worktree-${CMUX_WORKSPACE_ID:-manual}.dir\"; echo \"Waiting for worktree (timeout 60s)...\"; elapsed=0; while [ ! -s \"$state\" ]; do sleep 0.2; elapsed=$((elapsed + 1)); if [ $elapsed -ge 300 ]; then echo \"ERROR: worktree setup timed out after 60s\" >&2; exec \"${SHELL:-/bin/zsh}\" -l; fi; done; dir=$(cat \"$state\"); cd \"$dir\"; exec codex"
                      }
                    ]
                  }
                },
                {
                  "pane": {
                    "surfaces": [
                      {
                        "type": "terminal",
                        "name": "Claude",
                        "command": "state=\"${TMPDIR:-/tmp}/cmux-worktree-${CMUX_WORKSPACE_ID:-manual}.dir\"; echo \"Waiting for worktree (timeout 60s)...\"; elapsed=0; while [ ! -s \"$state\" ]; do sleep 0.2; elapsed=$((elapsed + 1)); if [ $elapsed -ge 300 ]; then echo \"ERROR: worktree setup timed out after 60s\" >&2; exec \"${SHELL:-/bin/zsh}\" -l; fi; done; dir=$(cat \"$state\"); cd \"$dir\"; exec claude"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      }
    },
    {
      "name": "PR Review Agent",
      "description": "Prompt for PR number, set up a review worktree on knowledge-work/knowledgework, and launch Claude reading REVIEW_TASK.md",
      "workspace": {
        "name": "PR Review Agent",
        "cwd": ".",
        "layout": {
          "direction": "horizontal",
          "split": 0.38,
          "children": [
            {
              "pane": {
                "surfaces": [
                  {
                    "type": "terminal",
                    "name": "Setup",
                    "command": "set -euo pipefail; state=\"${TMPDIR:-/tmp}/cmux-pr-review-${CMUX_WORKSPACE_ID:-manual}.dir\"; rm -f \"$state\"; printf '\\033[1;33mPR Review Agent — knowledge-work/knowledgework\\033[0m\\n'; if [[ -n \"${CMUX_PR_NUMBER:-}\" ]]; then pr_num=\"$CMUX_PR_NUMBER\"; echo \"Auto: PR #$pr_num (from CMUX_PR_NUMBER)\"; else printf 'Enter PR number: '; read -r pr_num; fi; if ! [[ \"$pr_num\" =~ ^[0-9]+$ ]]; then echo \"ERROR: invalid PR number: $pr_num\" >&2; exec \"${SHELL:-/bin/zsh}\" -l; fi; ~/dotfiles/scripts/runtime/prepare-pr-review.sh \"$pr_num\" || { echo \"ERROR: prepare-pr-review.sh failed\" >&2; exec \"${SHELL:-/bin/zsh}\" -l; }; worktree=\"$HOME/projects/knowledge-work/knowledgework-review/.claude/worktrees/pr-${pr_num}\"; printf \"%s\\n\" \"$worktree\" > \"$state\"; cd \"$worktree\"; echo \"\"; echo \"--- Worktree ready. Claude pane will start automatically. ---\"; exec \"${SHELL:-/bin/zsh}\" -l",
                    "focus": true
                  }
                ]
              }
            },
            {
              "pane": {
                "surfaces": [
                  {
                    "type": "terminal",
                    "name": "Claude Review",
                    "command": "state=\"${TMPDIR:-/tmp}/cmux-pr-review-${CMUX_WORKSPACE_ID:-manual}.dir\"; echo \"Waiting for PR setup (timeout 300s)...\"; elapsed=0; while [ ! -s \"$state\" ]; do sleep 0.2; elapsed=$((elapsed + 1)); if [ $elapsed -ge 1500 ]; then echo \"ERROR: PR review setup timed out after 300s\" >&2; exec \"${SHELL:-/bin/zsh}\" -l; fi; done; dir=$(cat \"$state\"); cd \"$dir\"; echo \"\"; echo \"================================================\"; echo \"Worktree: $dir\"; echo \"Next: type '@REVIEW_TASK.md' and press Enter\"; echo \"================================================\"; echo \"\"; exec env CLAUDE_SKIP_TEST_GATE=1 claude --permission-mode auto --add-dir \"$HOME/Documents/Obsidian Vault\""
                  }
                ]
              }
            }
          ]
        }
      }
    }
  ]
}
