{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
		"CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
	},
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"includeCoAuthoredBy": false,
	"permissions": {
		"allow": [
			"Bash(npm run *)",
			"Bash(npx prettier *)",
			"Bash(npx eslint *)",
			"Bash(pnpm *)",
			"Bash(bun *)",
			"Bash(go build *)",
			"Bash(go test *)",
			"Bash(go run *)",
			"Bash(go mod *)",
			"Bash(git status *)",
			"Bash(git log *)",
			"Bash(git diff *)",
			"Bash(git branch *)",
			"Bash(git add *)",
			"Bash(git commit *)",
			"Bash(git worktree list)",
			"Bash(git worktree list *)",
			"Bash(ls *)",
			"Bash(which *)",
			"Bash(node --version)",
			"Bash(python3 --version)",
			"Bash(go version)",
			"Bash(git --version)",
			"Bash(npm --version)",
			"Bash(bun --version)",
			"Bash(pnpm --version)",
			"Bash(brew --version)",
			"Bash(rustc --version)",
			"Bash(cargo --version)",
			"Bash(pwd)",
			"Bash(brew list *)",
			"Bash(brew info *)",
			"Bash(codex exec *)",
			"Bash(gemini *)",
			"Bash(ruff *)",
			"Bash(npx oxlint *)",
			"Bash(npx @biomejs/biome *)",
			"Bash(*gh-unresolved-threads*)",
			"Bash(gh pr view *)",
			"Bash(gh pr checks *)",
			"Bash(gh pr diff *)",
			"Bash(gh pr list *)"
		],
		"deny": [
			"Bash(rm -rf *)",
			"Bash(git push --force *)",
			"Bash(git reset --hard *)",
			"Bash(git clean -f *)",
			"Bash(git checkout -- *)",
			"Bash(chmod 777 *)",
			"Bash(git commit --no-verify *)",
			"Bash(curl *)",
			"Bash(wget *)",
			"Bash(sudo *)",
			"Bash(ssh *)",
			"Bash(scp *)",
			"Bash(nc *)",
			"Bash(ncat *)",
			"Bash(netcat *)",
			"Read(.env*)",
			"Read(**/*.pem)",
			"Read(**/*credentials*)",
			"Read(**/token*.json)",
			"Read(**/*secret*)",
			"Read(**/*.key)",
			"Read(~/.ssh/**)",
			"Read(~/.aws/**)",
			"Write(~/.ssh/**)",
			"Write(~/.aws/**)"
		]
	},
	"model": "opus[1m]",
	"enableAllProjectMcpServers": false,
	"enabledMcpjsonServers": ["context7"],
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/session-load.js",
						"timeout": 15
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/runtime/checkpoint_recover.py 2>/dev/null || true",
						"timeout": 10
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/completion-gate.py",
						"timeout": 60,
						"statusMessage": "Completion gate..."
					},
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/session-save.js",
						"timeout": 15
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/learner/session-learner.py",
						"timeout": 15
					},
					{
						"type": "command",
						"command": "osascript -e 'display notification \"タスクが完了しました\" with title \"Claude Code\"'; afplay /System/Library/Sounds/Hero.aiff &"
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/session-save.js",
						"timeout": 15
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/learner/session-learner.py",
						"timeout": 15
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks user-prompt",
						"timeout": 5,
						"statusMessage": "Agent routing..."
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-bash",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "Bash(git commit *)",
				"hooks": [
					{
						"type": "command",
						"command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-commit",
						"timeout": 15,
						"statusMessage": "Commit check..."
					}
				]
			},
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-edit",
						"timeout": 10,
						"statusMessage": "Pre-edit check..."
					}
				]
			},
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/file-pattern-router.py",
						"timeout": 5,
						"statusMessage": "File routing..."
					}
				]
			},
			{
				"matcher": "Grep|Glob|Read",
				"hooks": [
					{
						"type": "command",
						"command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-search",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "WebSearch",
				"hooks": [
					{
						"type": "command",
						"command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-websearch",
						"timeout": 10
					}
				]
			},
			{
				"matcher": "mcp__.*",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/mcp-audit.py",
						"timeout": 5,
						"statusMessage": "MCP audit..."
					}
				]
			},
			{
				"matcher": "Bash(*docker*)",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/docker-safety.py",
						"timeout": 5
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks post-edit",
						"timeout": 30,
						"statusMessage": "Format + check..."
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks post-bash",
						"timeout": 30,
						"statusMessage": "Analysis..."
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/stagnation-detector.py",
						"timeout": 5,
						"statusMessage": "Stagnation check..."
					}
				]
			},
			{
				"matcher": "Write",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/file-proliferation-guard.py",
						"timeout": 5,
						"statusMessage": "File proliferation check..."
					}
				]
			},
			{
				"matcher": "Skill",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/skill-tracker.py",
						"timeout": 5
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks post-any",
						"timeout": 5,
						"statusMessage": "Observing..."
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/pre-compact-save.js && bash $HOME/dotfiles/tools/half-clone/half-clone.sh",
						"timeout": 15
					}
				]
			}
		],
		"SubagentStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/runtime/subagent-monitor.py",
						"timeout": 5
					}
				]
			}
		],
		"Notification": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "osascript -e 'display notification \"Claude Code が入力を待っています\" with title \"Claude Code\"'; afplay /System/Library/Sounds/Glass.aiff &"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "~/.claude/statusline.sh",
		"padding": 0
	},
	"enabledPlugins": {
		"gopls-lsp@claude-plugins-official": true,
		"superpowers@claude-plugins-official": true,
		"frontend-design@claude-code-plugins": true,
		"code-simplifier@claude-plugins-official": true,
		"playground@claude-plugins-official": true,
		"pr-review-toolkit@claude-code-plugins": true,
		"datadog@kw-marketplace": true,
		"claude-md-management@claude-plugins-official": true,
		"rust-analyzer-lsp@claude-plugins-official": true
	},
	"language": "japanese",
	"effortLevel": "high",
	"plansDirectory": "./tmp/plans"
}
