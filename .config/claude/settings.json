{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
		"CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
	},
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"includeCoAuthoredBy": false,
	"permissions": {
		"allow": [
			"Bash(npm run *)",
			"Bash(npx prettier *)",
			"Bash(npx eslint *)",
			"Bash(pnpm *)",
			"Bash(bun *)",
			"Bash(go build *)",
			"Bash(go test *)",
			"Bash(go run *)",
			"Bash(go mod *)",
			"Bash(git status *)",
			"Bash(git log *)",
			"Bash(git diff *)",
			"Bash(git branch *)",
			"Bash(git add *)",
			"Bash(git commit *)",
			"Bash(git worktree list)",
			"Bash(git worktree list *)",
			"Bash(ls *)",
			"Bash(which *)",
			"Bash(node --version)",
			"Bash(python3 --version)",
			"Bash(go version)",
			"Bash(git --version)",
			"Bash(npm --version)",
			"Bash(bun --version)",
			"Bash(pnpm --version)",
			"Bash(brew --version)",
			"Bash(rustc --version)",
			"Bash(cargo --version)",
			"Bash(pwd)",
			"Bash(brew list *)",
			"Bash(brew info *)",
			"Bash(codex exec *)",
			"Bash(gemini *)",
			"Bash(ruff *)",
			"Bash(npx oxlint *)",
			"Bash(npx @biomejs/biome *)"
		],
		"deny": [
			"Bash(rm -rf *)",
			"Bash(git push --force *)",
			"Bash(git reset --hard *)",
			"Bash(git clean -f *)",
			"Bash(git checkout -- *)",
			"Bash(chmod 777 *)",
			"Bash(git commit --no-verify *)",
			"Bash(curl *)",
			"Bash(wget *)",
			"Bash(sudo *)",
			"Read(.env*)",
			"Read(**/*.pem)",
			"Read(**/*credentials*)"
		]
	},
	"model": "opus",
	"plansDirectory": "./tmp/plans",
	"enableAllProjectMcpServers": false,
	"enabledMcpjsonServers": ["context7"],
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/session-load.js",
						"timeout": 15
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/runtime/checkpoint_recover.py 2>/dev/null || true",
						"timeout": 10
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/completion-gate.py",
						"timeout": 60,
						"statusMessage": "Completion gate..."
					},
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/session-save.js",
						"timeout": 15
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/learner/session-learner.py",
						"timeout": 15
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/session-save.js",
						"timeout": 15
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/learner/session-learner.py",
						"timeout": 15
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/agent-router.py",
						"timeout": 10,
						"statusMessage": "Agent routing..."
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash(git commit *)",
				"hooks": [
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/policy/pre-commit-check.js",
						"timeout": 15,
						"statusMessage": "Commit message check..."
					}
				]
			},
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/protect-linter-config.py",
						"timeout": 10,
						"statusMessage": "Linter config guard..."
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/search-first-gate.py",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "Grep|Glob|Read",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/search-first-gate.py",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "WebSearch",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/suggest-gemini.py",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/auto-format.js",
						"timeout": 30,
						"statusMessage": "Auto-formatting..."
					},
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/suggest-compact.js",
						"timeout": 10
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/golden-check.py",
						"timeout": 15,
						"statusMessage": "Golden principles check..."
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/runtime/checkpoint_manager.py",
						"timeout": 10
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/runtime/output-offload.py",
						"timeout": 15
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/error-to-codex.py",
						"timeout": 15,
						"statusMessage": "Error analysis..."
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/post-test-analysis.py",
						"timeout": 30,
						"statusMessage": "Test analysis..."
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/lifecycle/plan-lifecycle.py",
						"timeout": 15
					},
					{
						"type": "command",
						"command": "python3 $HOME/.claude/scripts/policy/review-feedback-tracker.py",
						"timeout": 15,
						"statusMessage": "Review feedback tracking..."
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node $HOME/.claude/scripts/runtime/pre-compact-save.js",
						"timeout": 15
					}
				]
			}
		],
		"Notification": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "osascript -e 'display notification \"Claude Code が入力を待っています\" with title \"Claude Code\"'; afplay /System/Library/Sounds/Glass.aiff &"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "~/.claude/statusline.sh",
		"padding": 0
	},
	"enabledPlugins": {
		"gopls-lsp@claude-plugins-official": true,
		"superpowers@superpowers-marketplace": true,
		"frontend-design@claude-code-plugins": true,
		"code-simplifier@claude-plugins-official": true,
		"playground@claude-plugins-official": true,
		"pr-review-toolkit@claude-code-plugins": true,
		"datadog@kw-marketplace": true,
		"claude-md-management@claude-plugins-official": true
	},
	"language": "japanese",
	"effortLevel": "high"
}
