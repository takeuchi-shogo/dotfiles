{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx prettier *)",
      "Bash(npx eslint *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go run *)",
      "Bash(go mod *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git worktree list)",
      "Bash(git worktree list *)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(node --version)",
      "Bash(python3 --version)",
      "Bash(go version)",
      "Bash(git --version)",
      "Bash(npm --version)",
      "Bash(bun --version)",
      "Bash(pnpm --version)",
      "Bash(brew --version)",
      "Bash(rustc --version)",
      "Bash(cargo --version)",
      "Bash(pwd)",
      "Bash(brew list *)",
      "Bash(brew info *)",
      "Bash(codex exec *)",
      "Bash(gemini *)",
      "Bash(ruff *)",
      "Bash(npx oxlint *)",
      "Bash(npx @biomejs/biome *)",
      "WebFetch(*)",
      "WebSearch",
      "Bash(*gh-unresolved-threads*)",
      "Bash(gh pr view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(npx ecc-agentshield *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(tree *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(jq *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(shasum *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(date *)",
      "Bash(uname *)",
      "Read",
      "Glob",
      "Grep",
      "Agent(Explore)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git checkout -- *)",
      "Bash(chmod 777 *)",
      "Bash(git commit --no-verify *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(netcat *)",
      "Bash(osascript *)",
      "Bash(security *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(open *)",
      "Bash(printenv *)",
      "Bash(printenv)",
      "Bash(env)",
      "Bash(* .env*)",
      "Bash(* ~/.ssh/*)",
      "Bash(* ~/.aws/*)",
      "Bash(* ~/.gnupg/*)",
      "Bash(* ~/.azure/*)",
      "Bash(* ~/.kube/*)",
      "Bash(* ~/.config/gcloud/*)",
      "Bash(* ~/.docker/*)",
      "Bash(* ~/.config/gh/*)",
      "Bash(* ~/.git-credentials)",
      "Bash(* ~/.netrc)",
      "Bash(* ~/.npmrc)",
      "Bash(* ~/.vault-token)",
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(**/.envrc)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*credentials*)",
      "Read(**/token*.json)",
      "Read(**/*secret*)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Read(**/*password*)",
      "Read(**/*passwd*)",
      "Read(**/private_key*)",
      "Read(**/.htpasswd)",
      "Read(**/*.kdbx)",
      "Read(**/auth.json)",
      "Read(~/.password-store/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.kube/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.vault-token)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Write(~/.ssh/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.aws/**)",
      "Write(~/.azure/**)",
      "Write(~/.kube/**)",
      "Write(~/.config/gcloud/**)",
      "Write(~/.docker/config.json)",
      "Write(~/.vault-token)",
      "Write(~/.config/gh/**)",
      "Write(~/.git-credentials)",
      "Write(~/.netrc)",
      "Write(~/.npmrc)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.azure/**)",
      "Edit(~/.kube/**)",
      "Edit(~/.config/gcloud/**)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.vault-token)",
      "Edit(~/.config/gh/**)",
      "Edit(~/.git-credentials)",
      "Edit(~/.netrc)",
      "Edit(~/.npmrc)",
      "Edit(~/.zshrc)",
      "Write(~/.zshrc)",
      "Edit(~/.bashrc)",
      "Write(~/.bashrc)",
      "Edit(~/.zprofile)",
      "Write(~/.zprofile)",
      "Edit(~/.bash_profile)",
      "Write(~/.bash_profile)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [
    "context7",
    "alphaxiv",
    "code-review-graph"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/runtime/session-load.js",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/checkpoint_recover.py 2>/dev/null || true",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "date +%s > /tmp/claude-session-start.txt",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/env-bootstrap.py",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/memory-integrity-check.py",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/harness-snapshot.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/memory-vec-hint-hook.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/completion-gate.py",
            "timeout": 60,
            "statusMessage": "Completion gate..."
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/diff-coverage-gate.py",
            "timeout": 10,
            "statusMessage": "Diff coverage check..."
          },
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/runtime/session-save.js",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "(python3 $HOME/.claude/scripts/learner/session-learner.py && python3 $HOME/.claude/scripts/learner/failure-clusterer.py) >> /tmp/claude-learner.log 2>&1 &",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/learner/session-trace-store.py >> /tmp/claude-learner.log 2>&1 &",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "OBSIDIAN_VAULT_PATH=\"${OBSIDIAN_VAULT_PATH:-$HOME/Documents/Obsidian Vault}\" bash $HOME/.claude/scripts/runtime/sync-memory-to-vault.sh >> /tmp/obsidian-sync.log 2>&1 &",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/scripts/lifecycle/session-stats.sh >> /tmp/claude-stats.log 2>&1 &",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash -c 'START=$(cat /tmp/claude-session-start.txt 2>/dev/null || echo 0); NOW=$(date +%s); ELAPSED=$((NOW - START)); if [ $ELAPSED -gt 300 ]; then MINS=$((ELAPSED / 60)); bash $HOME/.claude/scripts/runtime/cmux-notify.sh \"Claude Code\" \"タスク完了 (${MINS}分)\" hero; else bash $HOME/.claude/scripts/runtime/cmux-notify.sh \"Claude Code\" \"タスクが完了しました\" hero; fi' > /dev/null 2>&1 &",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Blow.aiff 2>/dev/null &",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/memory-vec-stop-hook.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks user-prompt",
            "timeout": 5,
            "statusMessage": "Agent routing..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/user-input-guard.py",
            "timeout": 5,
            "statusMessage": "Input guard..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-bash",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-commit",
            "timeout": 15,
            "statusMessage": "Commit check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-edit",
            "timeout": 10,
            "statusMessage": "Pre-edit check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/prompt-injection-detector.py",
            "timeout": 5,
            "statusMessage": "Injection check..."
          }
        ]
      },
      {
        "matcher": "Grep|Glob|Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-search",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks pre-websearch",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/mcp-audit.py",
            "timeout": 5,
            "statusMessage": "MCP audit..."
          }
        ]
      },
      {
        "matcher": "Bash(*docker*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/docker-safety.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks post-edit",
            "timeout": 30,
            "statusMessage": "Format + check..."
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/claudemd-size-check.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks post-bash",
            "timeout": 30,
            "statusMessage": "Analysis..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/stagnation-detector.py",
            "timeout": 5,
            "statusMessage": "Friction check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/error-rate-monitor.py",
            "timeout": 5,
            "statusMessage": "Error rate check..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/file-proliferation-guard.py",
            "timeout": 5,
            "statusMessage": "File proliferation check..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/spec-quality-check.py",
            "timeout": 5,
            "statusMessage": "Spec quality check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/type-safety-delta.py",
            "timeout": 5,
            "statusMessage": "Type safety check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/impact-scan.py",
            "timeout": 8,
            "statusMessage": "Impact scan..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/mcp-skill-hint.py",
            "timeout": 3,
            "statusMessage": "MCP skill hint..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/approval-fatigue-guard.py",
            "timeout": 5,
            "statusMessage": "Fatigue check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/lifecycle/doc-garden-check.py",
            "timeout": 5,
            "statusMessage": "Doc garden check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/structure-check.py",
            "timeout": 5,
            "statusMessage": "Structure check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/skill-suggest.py",
            "timeout": 5,
            "statusMessage": "Skill suggest..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/change-surface-advisor.py",
            "timeout": 5,
            "statusMessage": "Change surface check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; case \"$f\" in */.claude/projects/*/memory/*.md) [ \"$(basename \"$f\")\" = \"MEMORY.md\" ] && exit 0; today=$(date +%Y-%m-%d); grep -q \"^updated_at:\" \"$f\" && sed -i '' \"s/^updated_at: .*/updated_at: $today/\" \"$f\" && echo '{\"suppressOutput\":true}' ;; esac; }",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in */.claude/projects/*/memory/*.md) [ \"$(basename \"$f\")\" = \"MEMORY.md\" ] && exit 0; export OBSIDIAN_VAULT_PATH=\"$HOME/Documents/Obsidian Vault\"; $HOME/.config/claude/scripts/runtime/sync-memory-to-vault.sh >> /tmp/obsidian-sync.log 2>&1 & ;; esac; }",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/mcp-response-inspector.py",
            "timeout": 5,
            "statusMessage": "MCP response check..."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/rationalization-scanner.py",
            "timeout": 5,
            "statusMessage": "Rationalization check..."
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/agent-invocation-logger.py",
            "timeout": 3,
            "statusMessage": "Logging agent invocation..."
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/scripts/runtime/cmux-notify.sh 'Claude Code' 'サブエージェント完了' default > /dev/null 2>&1 &",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/derivation-honesty-hook.py",
            "timeout": 5,
            "statusMessage": "Derivation honesty check..."
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/policy/skill-tracker.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/scripts/runtime/save-briefing-to-vault.sh",
            "timeout": 10,
            "statusMessage": "Saving briefing to Vault..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tools/claude-hooks/target/release/claude-hooks post-any",
            "timeout": 5,
            "statusMessage": "Observing..."
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/webfetch-truncation-detector.py",
            "timeout": 5,
            "statusMessage": "WebFetch truncation check..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/runtime/pre-compact-save.js && bash $HOME/dotfiles/tools/half-clone/half-clone.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/scripts/runtime/post-compact-verify.js",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/runtime/subagent-monitor.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/scripts/runtime/cmux-notify.sh 'Claude Code' 'Claude Code が入力を待っています' glass"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true,
    "code-simplifier@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "datadog@kw-marketplace": true,
    "claude-md-management@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "typescript-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "terraform-skill@antonbabenko-terraform": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "obsidian-skills": {
